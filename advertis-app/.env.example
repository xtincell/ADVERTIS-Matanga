# ADVERTIS SaaS - Environment Variables
# Copy this file to .env and fill in the values
#
# Required in ALL environments:
#   DATABASE_URL, AUTH_SECRET
#
# Required in PRODUCTION:
#   ANTHROPIC_API_KEY (optional in dev — AI features silently disabled)

# ─── Database ────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, or self-hosted)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/advertis_dev

# ─── Authentication ──────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your-auth-secret-here

# ─── AI / Anthropic ──────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ────────────────────────────────────────────────────
# NODE_ENV=development  (development | test | production)
# SKIP_ENV_VALIDATION=1 (skip env validation during Docker builds)
